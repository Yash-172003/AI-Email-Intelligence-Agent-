    {
      "parameters": {
        "jsCode": "const items = [];\n\nconst email = $('Get a message').first().json;\n\nconst sender = email.from.value[0].address || 'Unknown';\nconst name = email.to.value[0].name || 'Unknown';\nconst timestamp = email.date || new Date().toISOString();\nconst subject = email.subject;\n\nfor (const item of $input.all()) {\n\n  const response = item.json;\n\n  let summary = 'No summary available';\n\n  if (Array.isArray(response) && response.length > 0) {\n    if (response[0].summary_text) {\n      summary = response[0].summary_text;\n    }\n  } else if (response.summary_text) {\n    summary = response.summary_text;\n  } else if (response.error) {\n    summary = 'Error: ' + response.error;\n  }\n\n  const categorisingData = $('categorising').first().json;\n\n  let cat = 'Uncategorized';\n\n  if (Array.isArray(categorisingData) && categorisingData.length > 0) {\n    cat = categorisingData[0].label || cat;\n  }\n\n  items.push({\n    json: {\n      sender_email: sender,\n      sender_name: name,\n      timestamp: timestamp,\n      summary: summary,\n      category: cat,\n      is_spam: 'FALSE',\n      subject: subject\n    }\n  });\n}\n\nreturn items;"
      },
