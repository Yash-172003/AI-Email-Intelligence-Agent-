        "jsCode": "// Code node for Spam formatting\nconst items = [];\n\nfor (const item of $input.all()) {\n  // Extract data from previous nodes\n  const emailData = item.json;\n  \n  // Get sender email\n  const sender = $('Get a message').first().json.from.value[0].address || 'Unknown';\n\n  const name = $('Get a message').first().json.to.value[0].name || 'Unknown';\n  \n  // Get timestamp\n  const timestamp = $('Get a message').first().json.date || new Date().toISOString();\n  \n  items.push({\n    json: {\n      is_spam: 'TRUE',\n      sender_email: sender,\n      sender_name: name,\n      timestamp: timestamp,\n      category:'spam',\n      subject: $('Get a message').first().json.subject\n    }\n  });\n}\n\nreturn items;\n"
